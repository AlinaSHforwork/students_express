<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <title>Gotham Villain Registry</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Rajdhani:wght@400;600;700&display=swap');

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Rajdhani', sans-serif;
            padding: 30px 20px;
            max-width: 860px;
            margin: auto;
            background-color: #0a0a0f;
            color: #c9d1d9;
            background-image: radial-gradient(ellipse at top, #0d1117 0%, #0a0a0f 100%);
        }

        h2 {
            font-family: 'Bebas Neue', cursive;
            font-size: 2rem;
            color: #f0c040;
            letter-spacing: 3px;
            border-bottom: 2px solid #1c2a3a;
            padding-bottom: 10px;
            margin-bottom: 20px;
        }

        .form-group { margin-bottom: 14px; }

        .form-group label {
            display: block;
            margin-bottom: 5px;
            font-weight: 700;
            font-size: 0.85rem;
            letter-spacing: 1px;
            text-transform: uppercase;
            color: #8b949e;
        }

        .form-group input,
        .form-group select {
            width: 100%;
            padding: 10px 14px;
            background-color: #0d1117;
            border: 1px solid #1c2a3a;
            color: #c9d1d9;
            border-radius: 4px;
            font-family: 'Rajdhani', sans-serif;
            font-size: 1rem;
            transition: border-color 0.2s;
        }

        .form-group input:focus,
        .form-group select:focus {
            outline: none;
            border-color: #f0c040;
            background-color: #111722;
        }

        .form-group input::placeholder { color: #3d4a5a; }

        .card {
            background: #0d1117;
            padding: 24px;
            border-radius: 8px;
            margin-bottom: 40px;
            border: 1px solid #1c2a3a;
            box-shadow: 0 4px 20px rgba(0,0,0,0.5);
        }

        .villain-item {
            background: #0d1117;
            border: 1px solid #1c2a3a;
            padding: 18px;
            margin-bottom: 14px;
            border-radius: 6px;
            border-left: 4px solid #f0c040;
            transition: border-color 0.2s;
        }

        .villain-item:hover { border-left-color: #e53e3e; }

        .villain-item h3 {
            font-family: 'Bebas Neue', cursive;
            font-size: 1.4rem;
            color: #f0c040;
            letter-spacing: 2px;
            margin-bottom: 8px;
        }

        .villain-item p { margin-bottom: 4px; font-size: 0.95rem; line-height: 1.6; }

        .status-active    { color: #e53e3e; font-weight: 700; }
        .status-captured  { color: #68d391; font-weight: 700; }
        .status-neutralized { color: #8b949e; font-weight: 700; }

        .btn {
            padding: 9px 16px;
            cursor: pointer;
            border: none;
            border-radius: 4px;
            color: white;
            margin-right: 6px;
            text-decoration: none;
            display: inline-block;
            font-family: 'Rajdhani', sans-serif;
            font-size: 0.9rem;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
            transition: background-color 0.2s;
        }

        .btn-submit {
            background-color: #f0c040;
            color: #0a0a0f;
            font-size: 1rem;
            width: 100%;
            margin-top: 10px;
        }
        .btn-submit:hover { background-color: #d4a017; }

        .btn-edit { background-color: #2d3f55; color: #f0c040; }
        .btn-edit:hover { background-color: #3a5068; }

        .btn-delete { background-color: #2d1a1a; color: #e53e3e; }
        .btn-delete:hover { background-color: #4a2020; }

        .btn-back {
            background-color: #0d1117;
            color: #8b949e;
            border: 1px solid #1c2a3a;
            margin-bottom: 20px;
        }
        .btn-back:hover { background-color: #1c2a3a; color: #c9d1d9; }

        hr { border: none; border-top: 2px solid #1c2a3a; margin: 30px 0; }

        .empty-msg { color: #3d4a5a; font-style: italic; font-size: 1rem; }

        small { color: #3d4a5a; font-size: 0.8rem; }

        .bat-header {
            text-align: center;
            margin-bottom: 30px;
        }

        .bat-header h1 {
            font-family: 'Bebas Neue', cursive;
            font-size: 3rem;
            color: #f0c040;
            letter-spacing: 6px;
        }

        .bat-header p {
            color: #3d4a5a;
            font-size: 0.85rem;
            letter-spacing: 2px;
            text-transform: uppercase;
        }
    </style>
</head>
<body>

    <div class="bat-header">
        <h1>🦇 Gotham Villain Registry</h1>
        <p>Gotham City Police Department — Classified Files</p>
    </div>

    <a href="/" class="btn btn-back">⬅ Назад</a>

    {{#if editingVillain}}
        <a href="/villains" class="btn btn-back">✕ Скасувати редагування</a>
        <h2>Оновити досьє: {{editingVillain.villain_name}}</h2>
    {{else}}
        <h2>Внести нового ворога</h2>
    {{/if}}

    <div class="card">
        <form action="{{#if editingVillain}}/villains/edit/{{editingVillain.id}}{{else}}/villains{{/if}}" method="POST">

            <div class="form-group">
                <label for="villain_name">Ім'я / Псевдонім</label>
                <input type="text" id="villain_name" name="villain_name" value="{{editingVillain.villain_name}}" placeholder="Joker, Bane, Scarecrow..." required>
            </div>

            <div class="form-group">
                <label for="location">Локація в Готемі</label>
                <input type="text" id="location" name="location" value="{{editingVillain.location}}" placeholder="Arkham Asylum, The Narrows, Downtown..." required>
            </div>

            <div class="form-group">
                <label for="threat_level">Рівень небезпеки</label>
                <input type="number" id="threat_level" name="threat_level" value="{{editingVillain.threat_level}}" placeholder="0 — нешкідливий, 100 — кінець Готема" min="0" required>
            </div>

            <div class="form-group">
                <label for="status">Статус</label>
                <select id="status" name="status">
                    <option value="active"      {{#if (eq editingVillain.status 'active')}}selected{{/if}}>🔴 Active — на волі</option>
                    <option value="captured"    {{#if (eq editingVillain.status 'captured')}}selected{{/if}}>🟢 Captured — в Аркемі</option>
                    <option value="neutralized" {{#if (eq editingVillain.status 'neutralized')}}selected{{/if}}>⚫ Neutralized — загроза усунена</option>
                </select>
            </div>

            <button type="submit" class="btn btn-submit">
                {{#if editingVillain}}💾 Оновити досьє{{else}}☠️ Внести в реєстр{{/if}}
            </button>
        </form>
    </div>

    <hr>

    <h2>Реєстр ворогів Готема</h2>

    <div id="villains-list">
        {{#each villains}}
            <div class="villain-item" id="villain-{{this.id}}">
                <h3>{{this.villain_name}}</h3>
                <p>
                    <strong>Локація:</strong> {{this.location}} &nbsp;|&nbsp;
                    <strong>Рівень небезпеки:</strong> {{this.threat_level}}
                </p>
                <p>
                    <strong>Статус:</strong>
                    <span class="status-{{this.status}}">
                        {{#if (eq this.status 'active')}}🔴 На волі{{/if}}
                        {{#if (eq this.status 'captured')}}🟢 В Аркемі{{/if}}
                        {{#if (eq this.status 'neutralized')}}⚫ Нейтралізований{{/if}}
                    </span>
                </p>
                <p><small>Зафіксовано: {{this.spotted_date}} о {{this.spotted_time}}</small></p>
                <br>
                <a href="/villains/edit/{{this.id}}" class="btn btn-edit">✏️ Редагувати</a>
                <button class="btn btn-delete delete-btn" data-id="{{this.id}}">💀 Видалити</button>
            </div>
        {{else}}
            <p class="empty-msg">Реєстр порожній. Готем тимчасово в безпеці.</p>
        {{/each}}
    </div>

    <script>
        document.querySelectorAll('.delete-btn').forEach(button => {
            button.addEventListener('click', async (e) => {
                const id = e.target.getAttribute('data-id');
                if (confirm('Видалити ворога з реєстру GCPD назавжди?')) {
                    try {
                        const res = await fetch(`/villains/${id}`, { method: 'DELETE' });
                        if (res.ok) {
                            document.getElementById(`villain-${id}`).remove();
                        } else {
                            alert('Помилка при видаленні. Альфред вже перевіряє.');
                        }
                    } catch (err) {
                        console.error('Бетмен: щось пішло не так:', err);
                    }
                }
            });
        });
    </script>
</body>
</html>